{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["DOM", "ES2020"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "tampermonkey"],
    "skipLibCheck": true,
    "useDefineForClassFields": false
  },
  "include": ["src/**/*.ts", "build.ts"]
}
